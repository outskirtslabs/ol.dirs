{:paths ["../src" "dev"]
 :deps {org.clojure/clojure {:mvn/version "1.12.1"}}
 :aliases
 {:cljd
  {:extra-deps {tensegritics/clojuredart
                {:git/url "https://github.com/ramblurr/ClojureDart"
                 :git/sha "79e636ed4e9e8f3b506670048778378d75377edc"}}
   :main-opts ["-m" "cljd.build"]}
  :cljd-test
  {:extra-paths ["../test"]}}
 :cljd/opts {:kind :dart
             :main ol.dirs.cljd.main
             :test-namespaces [ol.dirs.cljd-test]}}
