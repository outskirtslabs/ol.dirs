(ns ol.dirs.cljd-test
  {:no-dynamic true}
  (:require [cljd.test :as t]
            [ol.dirs.impl :as impl]))

(def linux-context
  {:os :linux
   :home "/home/alice"
   :pid 4242
   :path-separator "/"
   :path-list-separator ":"
   :env {"XDG_DATA_HOME" "/tmp/data-home"
         "XDG_CONFIG_HOME" "/tmp/config-home"
         "XDG_STATE_HOME" "/tmp/state-home"
         "XDG_CACHE_HOME" "/tmp/cache-home"
         "XDG_DATA_DIRS" "/opt/share:/usr/share"}
   :user-dirs-content "XDG_DOWNLOAD_DIR=\"$HOME/Downloads\"\n"})

(t/deftest linux-public-resolution
  (t/is (= "/tmp/config-home/my-app"
           (impl/resolve-directory linux-context :config-home "My App")))
  (t/is (= ["/opt/share/my-app" "/usr/share/my-app"]
           (impl/resolve-directory linux-context :data-dirs "My App")))
  (t/is (= "/home/alice/Downloads"
           (:download-dir (impl/base-directories linux-context)))))

(t/deftest windows-home-env-helper
  (t/is (= "C:\\Users\\Alice"
           (impl/windows-home-directory {"USERPROFILE" "C:\\Users\\Alice"}))))
